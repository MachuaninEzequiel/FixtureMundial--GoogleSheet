{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "devCommand": "cd frontend && npm run dev",
  "outputDirectory": "frontend/dist",

  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(login|ranking|simulacion|torneo-privado|perfil)(.*)",
      "destination": "/index.html"
    }
  ]
}