# Variables de entorno — Serverless Functions (Vercel Runtime)
# Configurar en Vercel Dashboard > Settings > Environment Variables

# Google Sheets
SHEET_ID=1Abc...                     # ID del Google Sheet (parte larga de la URL)

# Service Account para Google Sheets API
# Pegar el JSON completo del service account en UNA sola línea (minificado)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase Admin SDK (para verificar tokens del frontend)
# Descargar de Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
